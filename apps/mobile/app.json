{
  "expo": {
    "name": "XIV Venue Manager",
    "slug": "xiv-venue-manager",
    "version": "1.0.0",
    "scheme": "vmapp",
    "orientation": "portrait",
    "platforms": [
      "android"
    ],
    "android": {
      "package": "com.xivvenuemanager.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e1e2e"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "vmapp"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
