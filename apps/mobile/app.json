{
  "expo": {
    "name": "XIV Venue Manager",
    "slug": "xiv-venue-manager",
    "version": "1.0.0",
    "scheme": "vmapp",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#1e1e2e",
      "resizeMode": "contain"
    },
    "platforms": [
      "android"
    ],
    "android": {
      "package": "com.xivvenuemanager.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e1e2e"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "vmapp"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["expo-notifications", { "icon": "./assets/icon.png", "color": "#1e1e2e" }]    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "0ec04efe-337b-4f50-a49e-3a8b7c53b882"
      }
    },
    "owner": "ehno"
  }
}
