// Prisma Schema for FFXIV Venue Manager
// Multi-tenant SaaS platform for managing FFXIV RP venues

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  discordId     String?   @unique
  displayName   String?
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts               Account[]
  sessions               Session[]
  memberships            Membership[]
  createdEvents          Event[]                 @relation("EventCreator")
  createdEventTemplates  EventTemplate[]         @relation("EventTemplateCreator")
  assignedTasks          Task[]                  @relation("AssignedTasks")
  completedTasks         Task[]                  @relation("TaskCompleter")
  transactions           Transaction[]
  paidPayrollEntries     PayrollEntry[]          @relation("PayrollPaidBy")
  feedback               Feedback[]
  reviewedFeedback       Feedback[]              @relation("FeedbackReviewer")
  patronLogs             PatronLog[]             @relation("PatronLogger")
  patronLogsWorking      PatronLog[]             @relation("PatronLogWorking")
  patronLogsReclassified PatronLog[]             @relation("PatronLogReclassifier")
  characters             UserCharacter[]
  apiKeys                ApiKey[]
  refreshTokens          RefreshToken[]
  deviceTokens           DeviceToken[]
  pendingNotifications   PendingNotification[]
  notificationPreference NotificationPreference?
  venueFollows           VenueFollow[]
  shoutTemplates         ShoutTemplate[]
  shiftAuditLogs         ShiftAuditLog[]
  notifications          Notification[]

  @@map("users")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // NEW_FOLLOWER | STAFF_JOINED | TASK_ASSIGNED | TASK_COMPLETED
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

model ShoutTemplate {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String
  fields      Json
  templateId  String
  separatorId String
  decorId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("shout_templates")
}

// Bridge between a user account and their FFXIV character(s). Required so
// the plugin (which only knows characterName + world) can classify a
// patron_log entry as "staff working" vs "patron" — shift state is per
// user, so we need the character → user lookup.
model UserCharacter {
  id            String   @id @default(cuid())
  userId        String
  characterName String
  world         String
  isPrimary     Boolean  @default(false)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([characterName, world])
  @@index([userId])
  @@map("user_characters")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// VENUES (Multi-tenant core entity)
// ============================================

model Venue {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?  @db.Text
  logoUrl       String?
  bannerUrl     String?
  galleryImages String[] @default([])

  // FFXIV Location
  dataCenter String
  world      String
  location   String? @db.Text

  // Settings
  timezone     String @default("UTC")
  currencyName String @default("Gil")
  settings     Json   @default("{\"taskVisibility\":\"all\",\"salesVisibility\":\"all\",\"revenueVisibility\":\"all\",\"eventVisibility\":\"all\",\"webhooks\":{\"taskCreated\":false,\"taskCompleted\":false,\"partakeEvent\":false,\"saleLogged\":false,\"dailySalesSummary\":false,\"staffJoined\":false},\"discordWebhooks\":{\"staff\":\"\",\"events\":\"\",\"revenue\":\"\"}}")

  // Partake Integration
  partakeTeamId Int?

  // Discord Integration (deprecated - kept for migration)
  discordWebhookUrl String?
  discordServerId   String?

  // Metadata
  ownerId   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  memberships    Membership[]
  events         Event[]
  eventTemplates EventTemplate[]
  roles          Role[]
  services       Service[]
  transactions   Transaction[]
  tasks          Task[]
  webhooks       Webhook[]
  payrollEntries PayrollEntry[]
  shifts         Shift[]
  patronLogs     PatronLog[]
  apiKeys        ApiKey[]
  follows        VenueFollow[]

  @@map("venues")
}

// ============================================
// MEMBERSHIPS & ROLES
// ============================================

enum MembershipRole {
  OWNER
  MANAGER
  STAFF
}

model Membership {
  id       String         @id @default(cuid())
  userId   String? // Nullable until invite is accepted
  venueId  String
  role     MembershipRole @default(STAFF)
  roleId   String? // Custom role assignment
  hireDate DateTime       @default(now())
  status   String         @default("pending") // pending, active, inactive

  // Invite system
  inviteToken     String?   @unique
  inviteExpiresAt DateTime?
  invitedBy       String? // User ID who created the invite
  invitedEmail    String? // Email for display purposes only (not used for auth)
  invitedName     String? // Name placeholder for invited staff

  // Compensation
  hourlyRate Decimal? @db.Decimal(10, 2) // Default hourly rate for this member at this venue

  // Temporary role system (for deputizing staff)
  temporaryRole          MembershipRole? // Elevated role while deputized
  temporaryRoleExpiresAt DateTime? // When temporary role expires
  permanentRole          MembershipRole? // Original role to revert back to

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User?                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue           Venue                      @relation(fields: [venueId], references: [id], onDelete: Cascade)
  customRole      Role?                      @relation(fields: [roleId], references: [id])
  additionalRoles MembershipRoleAssignment[]
  payrollEntries  PayrollEntry[]
  shifts          Shift[]

  @@index([venueId, userId])
  @@index([venueId, role])
  @@index([inviteToken])
  @@map("memberships")
}

model Role {
  id               String  @id @default(cuid())
  venueId          String
  name             String
  color            String? @default("#6366f1")
  responsibilities String? @db.Text
  permissions      Json    @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venue         Venue                      @relation(fields: [venueId], references: [id], onDelete: Cascade)
  memberships   Membership[]
  additionalFor MembershipRoleAssignment[]
  shifts        Shift[]
  services      Service[] // Services this role can provide
  assignedTasks Task[]                     @relation("RoleTasks") // Tasks assigned to this role

  @@unique([venueId, name])
  @@map("roles")
}

model MembershipRoleAssignment {
  id           String @id @default(cuid())
  membershipId String
  roleId       String

  createdAt DateTime @default(now())

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([membershipId, roleId])
  @@index([roleId])
  @@map("membership_role_assignments")
}

// ============================================
// EVENTS & CALENDAR
// ============================================

enum EventType {
  PERFORMANCE
  GAME_NIGHT
  SPECIAL
  SOCIAL
  PRIVATE
  OTHER
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ACTIVE
  COMPLETED
  CANCELLED
}

model Event {
  id          String      @id @default(cuid())
  venueId     String
  title       String
  description String?     @db.Text
  location    String?     @db.Text
  eventType   EventType   @default(OTHER)
  status      EventStatus @default(DRAFT)

  // Scheduling
  startTime DateTime
  endTime   DateTime
  timezone  String   @default("UTC")

  // Recurrence (future feature)
  recurrenceRule String? // iCal RRULE format
  parentEventId  String? // For recurring event instances

  // Partake sync
  partakeEventId       Int? @unique
  partakeAttendeeCount Int?

  // Discord post tracking (Partake mirror)
  discordMessageId      String?
  discordWebhookGroup   String?
  discordContentHash    String?
  discordCancelledAt    DateTime?
  discordReminderSentAt DateTime?

  // Tracking
  attendanceCount Int?
  revenue         Decimal? @db.Decimal(10, 2)

  // Metadata
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  venue        Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  createdBy    User          @relation("EventCreator", fields: [createdById], references: [id])
  parentEvent  Event?        @relation("EventRecurrence", fields: [parentEventId], references: [id])
  childEvents  Event[]       @relation("EventRecurrence")
  transactions Transaction[]
  patronLogs   PatronLog[]

  @@index([venueId, startTime])
  @@index([venueId, status])
  @@index([createdById])
  @@map("events")
}

model EventTemplate {
  id          String    @id @default(cuid())
  venueId     String
  name        String // Template name (e.g., "Weekly Trivia Night")
  title       String // Event title to use when creating from template
  description String?   @db.Text
  eventType   EventType @default(OTHER)
  timezone    String    @default("UTC")

  // Store default times as "HH:MM" format (e.g., "19:00", "22:00")
  defaultStartTime String @default("19:00") // 7:00 PM
  defaultEndTime   String @default("22:00") // 10:00 PM

  // Metadata
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  venue     Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  createdBy User  @relation("EventTemplateCreator", fields: [createdById], references: [id])

  @@index([venueId])
  @@map("event_templates")
}

// ============================================
// PATRON TRACKING
// ============================================

enum PatronAction {
  ENTER
  EXIT
}

model PatronLog {
  id            String   @id @default(cuid())
  venueId       String
  eventId       String? // Optional: associate with specific event
  characterName String? // FFXIV character name (from Dalamud plugin)
  world         String? // FFXIV home world (from Dalamud plugin)
  action        String   @default("ENTER") // ENTER, EXIT/LEAVE, PRESENT
  countChange   Int? // +1 for ENTER, -1 for EXIT (nullable for character-level logs)
  loggedBy      String? // User ID that logged this (staff or API key user)
  timestamp     DateTime @default(now()) // When the event actually happened
  loggedAt      DateTime @default(now()) // When the server received/recorded it

  // Was the character's user clocked into an ACTIVE shift at this venue
  // when they walked in? Snapshotted at insert time so later shift edits
  // don't rewrite history. Off-duty staff → wasWorking = false (they're
  // a patron that night).
  wasWorking    Boolean @default(false)
  workingUserId String? // The user whose character was on shift (only set when wasWorking=true)

  // Manual reclassification audit (OWNER/MANAGER override). Null = original snapshot, untouched.
  reclassifiedAt   DateTime?
  reclassifiedById String?
  reclassifyReason String?

  venue          Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  event          Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  staff          User?  @relation("PatronLogger", fields: [loggedBy], references: [id])
  workingUser    User?  @relation("PatronLogWorking", fields: [workingUserId], references: [id], onDelete: SetNull)
  reclassifiedBy User?  @relation("PatronLogReclassifier", fields: [reclassifiedById], references: [id], onDelete: SetNull)

  @@index([venueId, timestamp])
  @@index([eventId, timestamp])
  @@index([venueId, characterName])
  @@index([venueId, wasWorking, timestamp])
  @@map("patron_logs")
}

// ============================================
// SERVICES & TRANSACTIONS
// ============================================

model Service {
  id          String  @id @default(cuid())
  venueId     String
  name        String
  description String? @db.Text
  price       Decimal @db.Decimal(10, 2)
  category    String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venue        Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  roles        Role[] // Roles that can provide this service

  @@map("services")
}

enum TransactionType {
  SALE
  TIP
  COVER_CHARGE
  OTHER

  @@map("transaction_type")
}

model Transaction {
  id        String  @id @default(cuid())
  venueId   String
  eventId   String?
  serviceId String?
  staffId   String?

  // Transaction details
  type         TransactionType @default(SALE)
  amount       Decimal         @db.Decimal(10, 2)
  customerName String?
  notes        String?         @db.Text

  createdAt DateTime @default(now())

  venue   Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  event   Event?   @relation(fields: [eventId], references: [id])
  service Service? @relation(fields: [serviceId], references: [id])
  staff   User?    @relation(fields: [staffId], references: [id])

  @@index([venueId, createdAt])
  @@index([venueId, serviceId])
  @@index([staffId])
  @@map("transactions")
}

// ============================================
// TASKS & ASSIGNMENTS
// ============================================

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id             String  @id @default(cuid())
  venueId        String
  assignedTo     String?
  assignedRoleId String? // Role assigned to complete this task (alternative to assignedTo)

  // Task details
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  category    String? // setup, cleanup, promotional, etc.

  // Scheduling
  dueDate     DateTime?
  completedAt DateTime?
  completedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venue        Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  assignee     User? @relation("AssignedTasks", fields: [assignedTo], references: [id])
  assignedRole Role? @relation("RoleTasks", fields: [assignedRoleId], references: [id])
  completer    User? @relation("TaskCompleter", fields: [completedBy], references: [id])

  @@index([venueId, status, priority])
  @@index([assignedTo])
  @@index([assignedRoleId])
  @@map("tasks")
}

// ============================================
// PAYROLL & COMPENSATION
// ============================================

enum PaymentType {
  FIXED_SALARY // Set pay per period
  HOURLY // Pay per hour worked
}

model PayrollEntry {
  id           String  @id @default(cuid())
  venueId      String
  membershipId String? // Staff member being paid (null for manual entries)

  // Manual entry support (for temp DJs, contractors, etc.)
  isManualEntry   Boolean @default(false)
  manualEntryName String? // Name of person for manual entries

  // Payment configuration
  paymentType PaymentType
  baseRate    Decimal     @db.Decimal(10, 2) // Fixed salary or hourly rate
  hoursWorked Decimal?    @db.Decimal(6, 2) // For hourly payments
  bonusAmount Decimal?    @db.Decimal(10, 2) // Optional bonus
  totalAmount Decimal     @db.Decimal(10, 2) // Calculated total

  // Payment period
  periodStart DateTime
  periodEnd   DateTime

  // Payment status
  isPaid Boolean   @default(false)
  paidAt DateTime?
  paidBy String? // User ID who marked as paid

  // Additional details
  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venue      Venue       @relation(fields: [venueId], references: [id], onDelete: Cascade)
  membership Membership? @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  paidByUser User?       @relation("PayrollPaidBy", fields: [paidBy], references: [id])
  shifts     Shift[] // Shifts covered by this payroll entry

  @@index([venueId, periodEnd])
  @@index([membershipId, isPaid])
  @@index([venueId, isPaid])
  @@index([venueId, isManualEntry])
  @@map("payroll_entries")
}

// ============================================
// WEBHOOKS & INTEGRATIONS
// ============================================

enum WebhookEvent {
  TASK_COMPLETED
  EVENT_CREATED
  EVENT_REMINDER
  SALES_DAILY_SUMMARY
  STAFF_JOINED
}

model Webhook {
  id       String         @id @default(cuid())
  venueId  String
  name     String
  url      String
  events   WebhookEvent[]
  isActive Boolean        @default(true)

  // Template customization
  template Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@map("webhooks")
}

// ============================================
// USER FEEDBACK & SUPPORT
// ============================================

enum FeedbackCategory {
  BUG_REPORT
  FEATURE_REQUEST
  IMPROVEMENT
  GENERAL
}

enum FeedbackStatus {
  NEW
  UNDER_REVIEW
  PLANNED
  IN_PROGRESS
  COMPLETED
  WONT_FIX
}

model Feedback {
  id          String           @id @default(cuid())
  userId      String
  category    FeedbackCategory
  status      FeedbackStatus   @default(NEW)
  subject     String
  description String           @db.Text

  // Optional context
  url        String? // Page where feedback was submitted
  userAgent  String? // Browser/device info
  screenshot String? // Optional screenshot URL

  // Admin notes
  adminNotes String?   @db.Text
  reviewedBy String?
  reviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("FeedbackReviewer", fields: [reviewedBy], references: [id])

  @@index([userId])
  @@index([status, createdAt])
  @@index([category])
  @@map("feedback")
}

// ============================================
// PLUGIN / EXTERNAL API KEYS
// ============================================

model ApiKey {
  id         String    @id
  keyHash    String?   @unique
  keyPreview String?
  name       String
  userId     String
  venueId    String?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue? @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

// ============================================
// SHIFTS & TIME TRACKING
// ============================================

enum ShiftStatus {
  OPEN
  CLAIMED
  SCHEDULED
  ACTIVE
  COMPLETED
  MISSED
  CANCELLED
}

model Shift {
  id             String  @id @default(cuid())
  venueId        String
  membershipId   String?
  roleId         String?
  payrollEntryId String? // Links to the payroll entry that paid for this shift

  // Schedule (set by manager when creating the shift)
  scheduledStart DateTime
  scheduledEnd   DateTime

  // Actuals (set by staff via clock-in / clock-out)
  actualStart DateTime?
  actualEnd   DateTime?
  hoursWorked Decimal?  @db.Decimal(6, 2) // Stored at clock-out for immediate display

  status ShiftStatus @default(SCHEDULED)
  notes  String?     @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venue        Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  membership   Membership?   @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role         Role?         @relation(fields: [roleId], references: [id], onDelete: SetNull)
  payrollEntry PayrollEntry? @relation(fields: [payrollEntryId], references: [id], onDelete: SetNull)
  auditLogs    ShiftAuditLog[]

  @@index([venueId, scheduledStart])
  @@index([membershipId, status])
  @@index([venueId, status])
  @@index([payrollEntryId])
  @@index([roleId])
  @@map("shifts")
}

// Audit trail for clock-in/out and claim/approve/reject actions on a shift.
// actorUserId is null for system-initiated changes (e.g. auto-miss sweeps).
model ShiftAuditLog {
  id          String   @id @default(cuid())
  shiftId     String
  action      String // CLOCK_IN, CLOCK_OUT, CLAIM, APPROVE, REJECT
  actorUserId String?
  source      String // web, mobile_self, mobile_operator, plugin
  createdAt   DateTime @default(now())

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  actor User?  @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([shiftId])
  @@index([actorUserId])
  @@map("shift_audit_logs")
}

// ============================================
// PUSH NOTIFICATIONS (Phase 4)
// ============================================

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   @default("android")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

enum NotificationType {
  SHIFT_REMINDER
  SHIFT_CLAIM_APPROVED
  SHIFT_CLAIM_REJECTED
  SHIFT_CLAIM_SUBMITTED
  VENUE_OPENED_NOW
  EVENT_REMINDER_30M
}

model PendingNotification {
  id           String           @id @default(cuid())
  userId       String
  type         NotificationType
  title        String
  body         String
  data         Json?
  scheduledFor DateTime
  sentAt       DateTime?
  receiptId    String?
  createdAt    DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([scheduledFor, sentAt])
  @@index([userId])
  @@map("pending_notifications")
}

model NotificationPreference {
  id               String   @id @default(cuid())
  userId           String   @unique
  shiftReminder    Boolean  @default(true)
  venueOpenedNow   Boolean  @default(true)
  eventReminder    Boolean  @default(true)
  followVisibility Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model VenueFollow {
  id                 String   @id @default(cuid())
  userId             String
  venueId            String
  visibleToOperators Boolean  @default(false)
  createdAt          DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([userId, venueId])
  @@index([venueId])
  @@map("venue_follows")
}

model RefreshToken {
  id          String    @id
  userId      String
  tokenHash   String    @unique
  deviceLabel String?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  lastUsedAt  DateTime?
  revokedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}
