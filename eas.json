      "distribution": "internal",
      "projectSubdirectory": "apps/mobile",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_DISCORD_CLIENT_ID": "1442821194263957616"
      }
    },
    "preview": {
      "distribution": "internal",
