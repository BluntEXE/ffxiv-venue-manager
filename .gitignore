# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
docker/homepage/config/.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Keep .env.example committed
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# Local backups (from in-place edits)
*.bak
*.bak-*
.env.bak-*
.env.local.backup

# Local runtime data volumes (mounted into containers)
/docker/postgres/data
/docker/redis/data

# Playwright artefacts
test-results/
playwright-report/

# pnpm
.pnpm-store/

# Turbo
.turbo/

# Monorepo app build outputs
apps/web/.next/
apps/web/out/
packages/*/dist/

# Workspace app node_modules (pnpm symlinks)
apps/*/node_modules/
packages/*/node_modules/

# Android signing keystores
*.jks
*.keystore
*.apk
graphify-out/
app.json
eas.json
graphify-out/
.worktrees/
